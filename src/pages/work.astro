---
import Layout from "../layouts/Layout.astro";
import { workPageContent } from "../config";
import ResumeItem from "../components/ResumeItem.astro";
import CoverflowCarousel from "../components/CoverflowCarousel";
import {marked} from "marked"

const workDescription = marked.parse(workPageContent.description)

const certImages = [
  "/certifications/goldman-sachs.jpg",
  "/certifications/jpmc.jpg",
  "/certifications/anthropic.jpg",
];
---

<Layout seo={workPageContent.seo}>
  <section class="mt-10 max-w-3xl mx-auto px-6 scroll-reveal">
    <h1 class="font-bold text-3xl mb-10 text-center">Experience</h1>
    <div class="grid grid-cols-1 group">
      {workPageContent.items.map((item) => <ResumeItem {...item} />)}
    </div>
  </section>

  <section class="mt-20 mb-20 scroll-reveal">
    <h1 class="font-bold text-3xl mb-10 text-center">Certifications</h1>
    <CoverflowCarousel images={certImages} client:visible />
  </section>
</Layout>
