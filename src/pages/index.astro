---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { homePageContent, identity } from "../config";
import SocialLink from "../components/SocialLink.astro";
import Link from "../components/Link.astro";
import { getCollection } from "astro:content";

let posts = await getCollection("posts");
posts = posts.filter((p) => !p.data?.draft);
posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
posts.splice(3)
---

<Layout seo={homePageContent.seo}>
  <section class="mt-10 max-w-2xl mx-auto px-6 scroll-reveal">
    <h1 class="font-bold text-3xl mb-8">{identity.name}</h1>
    <div class="flex items-center gap-6 mb-8">
      <Image
        src={identity.logo}
        alt={identity.name}
        width={150}
        height={150}
        class="rounded-full shrink-0"
      />
      <div class="group flex flex-col gap-2">
        {
          homePageContent.socialLinks.map((link) => (
            <SocialLink
              title={link.title}
              url={link.url}
              icon={link.icon}
              external={link.external}
            />
          ))
        }
      </div>
    </div>
    <div class="text-base leading-relaxed mb-8 space-y-4">
  <p>I'm a junior at Columbia University studying Computer Science & Design, previously at NYU.</p>
  <p>I work on AI with <a href="https://openai.com" target="_blank" class="underline underline-offset-2 hover:opacity-100">OpenAI</a> and <a href="https://pfizer.com" target="_blank" class="underline underline-offset-2 hover:opacity-100">Pfizer</a>, and have published research at <a href="https://iclr.cc" target="_blank" class="underline underline-offset-2 hover:opacity-100">ICLR 2024</a> and <a href="https://ijcai.org" target="_blank" class="underline underline-offset-2 hover:opacity-100">IJCAI 2024</a> from my time at <a href="https://research.ibm.com" target="_blank" class="underline underline-offset-2 hover:opacity-100">IBM Research</a>.</p>
  <p>I work at the intersection of AI research, full-stack engineering, and human-centered design. Outside of work you'll find me hosting dinner parties, traveling the world, and experimenting with film photography.</p>
  <p>Recognized at ICLR 2024 (Notable), IBM/IEEE AICS 2023, Best Research Award at the University of Sharjah, Genius Olympiad Finalist, and WESEF Finalist.</p>
</div>
    <div class="flex items-center gap-4 group w-fit mb-8">
      {
        homePageContent.links.map((link) => (
          <Link text={link.title} href={link.url} external={link.external} />
        ))
      }
    </div>
  </section>
  <section class="mt-20 max-w-2xl mx-auto px-6 scroll-reveal">
    <h2 class="mb-8">Latest Posts</h2>
    <div class="grid grid-cols-1 gap-10 sm:gap-6 mb-10">
      {
        posts.map((post) => (
          <a
            href={`/blog/${post.id.replace(/\.md$/, '')}`}
            class=" sm:flex sm:flex-row-reverse sm:justify-between sm:gap-6 post"
          >
            <Image
              src={post.data.image.url}
              alt={post.data.image.url}
              width={100}
              height={100}
              class={"rounded-lg w-[100px] h-[100px] object-cover"}
            />
            <div class="mt-4 sm:my-auto">
              <p class="opacity-60 mb-2">
                {post.data.pubDate.toLocaleDateString()}
              </p>
              <h3 class="font-medium hover-underline">{post.data.title}</h3>
              <p class="text-sm opacity-60 mt-2 mb-3">{post.data.description}</p>
            </div>
          </a>
        ))
      }
    </div>
    <div class="text-center">
      <a
        href="/blog"
        class="underline underline-offset-4 opacity-60 hover:opacity-100 transition-opacity"
        >View all</a
      >
    </div>
  </section>
  {homePageContent.currentlyReading && homePageContent.currentlyReading.length > 0 && (
    <section class="mt-20 max-w-2xl mx-auto px-6 mb-20 scroll-reveal">
      <h2 class="mb-8">Recent Reads</h2>
      <ul class="space-y-3">
        {homePageContent.currentlyReading.map((book) => (
          <li class="flex items-baseline gap-2">
            {book.url ? (
              <a href={book.url} target="_blank" rel="noopener noreferrer" class="hover-underline font-medium">
                {book.title}
              </a>
            ) : (
              <span class="font-medium">{book.title}</span>
            )}
            <span class="opacity-60">by {book.author}</span>
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
