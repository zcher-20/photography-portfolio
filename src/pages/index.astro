---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { homePageContent, identity } from "../config";
import SocialLink from "../components/SocialLink.astro";
import Link from "../components/Link.astro";
import Letter3DSwap from "../components/Letter3DSwap.tsx";
import { getCollection } from "astro:content";

let posts = await getCollection("posts");
posts = posts.filter((p) => !p.data?.draft);
posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
posts.splice(3)
---

<Layout seo={homePageContent.seo}>
  <section class="mt-10 max-w-2xl mx-auto px-6 scroll-reveal">
    <h1 class="font-bold text-3xl mb-8">{identity.name}</h1>
    <div class="flex items-center gap-6 mb-8">
      <Image
        src={identity.logo}
        alt={identity.name}
        width={150}
        height={150}
        class="rounded-full shrink-0"
      />
      <div class="group flex flex-col gap-2">
        {
          homePageContent.socialLinks.map((link) => (
            <SocialLink
              title={link.title}
              url={link.url}
              icon={link.icon}
              external={link.external}
            />
          ))
        }
      </div>
    </div>
    <div class="text-base leading-relaxed mb-8 space-y-4">
  <p>I'm a junior at Columbia University studying Computer Science & Design, previously at NYU.</p>
  <p>I work on AI with <a href="https://openai.com" target="_blank" class="underline underline-offset-2 hover:opacity-100">OpenAI</a> and <a href="https://pfizer.com" target="_blank" class="underline underline-offset-2 hover:opacity-100">Pfizer</a>, and have published research at <a href="https://openreview.net/forum?id=hvp5I4dDya" target="_blank" class="underline underline-offset-2 hover:opacity-100">ICLR 2024</a> and <a href="https://www.ijcai.org/proceedings/2024/878" target="_blank" class="underline underline-offset-2 hover:opacity-100">IJCAI 2024</a> from my time at <a href="https://research.ibm.com" target="_blank" class="underline underline-offset-2 hover:opacity-100">IBM Research</a>. I'm currently building AI agents at an MIT-incubated startup and collaborating with Al Akhawayn University to extend <a href="https://huggingface.co/ibm-nasa-geospatial/Prithvi-100M" target="_blank" class="underline underline-offset-2 hover:opacity-100">NASA's Prithvi foundation model</a> for wildfire prediction in Morocco.</p>
  <p>I work at the intersection of AI research, full-stack engineering, and human-centered design. Outside of work you'll find me hosting dinner parties, traveling the world, and experimenting with film photography.</p>
  <p>Recognized for research excellence through ICLR 2024, the IBM/IEEE AICS 2023 competition, the Best Research Award at the University of Sharjah, and finalist selections at both the Genius Olympiad and WESEF.</p>
</div>
    <div class="flex items-center gap-4 group w-fit mb-8">
      {
        homePageContent.links.map((link) => (
          <Link text={link.title} href={link.url} external={link.external} />
        ))
      }
    </div>
  </section>
  {homePageContent.currentlyReading && homePageContent.currentlyReading.length > 0 && (
    <section class="mt-20 max-w-2xl mx-auto px-6 mb-20 scroll-reveal">
      <h2 class="mb-8">Recent Reads</h2>
      <ul class="space-y-3">
        {homePageContent.currentlyReading.map((book) => (
          <li class="flex items-baseline gap-2">
            {book.url ? (
              <a href={book.url} target="_blank" rel="noopener noreferrer" class="hover-underline font-medium">
                {book.title}
              </a>
            ) : (
              <span class="font-medium">{book.title}</span>
            )}
            <span class="opacity-60">by {book.author}</span>
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
