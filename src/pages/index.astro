---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { homePageContent, identity } from "../config";
import SocialLink from "../components/SocialLink.astro";
import Link from "../components/Link.astro";
import { getCollection } from "astro:content";

let posts = await getCollection("posts");
posts = posts.filter((p) => !p.data?.draft);
posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
posts.splice(3)
---

<Layout seo={homePageContent.seo}>
  <section class="mt-10 max-w-2xl mx-auto px-6 scroll-reveal">
    <h1 class="gradient-name font-bold text-3xl mb-8">{identity.name}</h1>
    <div class="flex items-center gap-6 mb-8">
      <div class="profile-glow shrink-0">
        <Image
          src={identity.logo}
          alt={identity.name}
          width={150}
          height={150}
          class="rounded-full"
        />
      </div>
      <div class="group flex flex-col gap-2">
        {
          homePageContent.socialLinks.map((link) => (
            <SocialLink
              title={link.title}
              url={link.url}
              icon={link.icon}
              external={link.external}
            />
          ))
        }
      </div>
    </div>
    <div class="text-base leading-relaxed mb-8 space-y-4">
      <p>I'm a junior at Columbia studying Computer Science and Math, and a Neo Scholar (2025 cohort).</p>
      <p>At Columbia, I research agent failure at <a href="https://daplab.cs.columbia.edu/" target="_blank" class="underline underline-offset-2 hover:opacity-100">DAPLab</a>, lead the <a href="https://www.cualignment.org/" target="_blank" class="underline underline-offset-2 hover:opacity-100">AI Alignment Club</a>, and am part of Columbia's entrepreneurship club, <a href="https://undergrad.admissions.columbia.edu/studentgroup/columbia-organization-rising-entrepreneurs-core" target="_blank" class="underline underline-offset-2 hover:opacity-100">CORE</a>. Previously, I worked on AI observability products at <a href="https://www.langchain.com" target="_blank" class="underline underline-offset-2 hover:opacity-100">LangChain</a>, and generative video models at <a href="https://pika.art" target="_blank" class="underline underline-offset-2 hover:opacity-100">Pika</a>.</p>
      <p>I enjoy pretty much anything outdoors, especially snowboarding and kitesurfing.</p>
    </div>
    <div class="flex items-center gap-4 group w-fit mb-8">
      {
        homePageContent.links.map((link) => (
          <Link text={link.title} href={link.url} external={link.external} />
        ))
      }
    </div>
  </section>
  <section class="mt-20 max-w-2xl mx-auto px-6">
    <h2 class="mb-8 scroll-reveal">Latest Posts</h2>
    <div class="stagger-container grid grid-cols-1 gap-10 sm:gap-6 mb-10">
      {
        posts.map((post) => (
          <a
            href={`/blog/${post.id.replace(/\.md$/, '')}`}
            class="tilt-card sm:flex sm:flex-row-reverse sm:justify-between sm:gap-6 post"
          >
            <div class="rounded-lg overflow-hidden w-[100px] h-[100px] shrink-0">
              <Image
                src={post.data.image.url}
                alt={post.data.image.url}
                width={100}
                height={100}
                class="post-img w-full h-full object-cover"
              />
            </div>
            <div class="mt-4 sm:my-auto">
              <p class="opacity-60 mb-2">
                {post.data.pubDate.toLocaleDateString()}
              </p>
              <h3 class="font-medium hover-underline">{post.data.title}</h3>
              <p class="text-sm opacity-60 mt-2 mb-3">{post.data.description}</p>
            </div>
          </a>
        ))
      }
    </div>
    <div class="text-center">
      <a
        href="/blog"
        class="underline underline-offset-4 opacity-60 hover:opacity-100 transition-opacity"
        >View all</a
      >
    </div>
  </section>
  {homePageContent.currentlyReading && homePageContent.currentlyReading.length > 0 && (
    <section class="mt-20 max-w-2xl mx-auto px-6 mb-20 scroll-reveal">
      <h2 class="mb-8">Recent Reads</h2>
      <ul class="stagger-container space-y-3">
        {homePageContent.currentlyReading.map((book) => (
          <li class="flex items-baseline gap-2">
            {book.url ? (
              <a href={book.url} target="_blank" rel="noopener noreferrer" class="hover-underline font-medium">
                {book.title}
              </a>
            ) : (
              <span class="font-medium">{book.title}</span>
            )}
            <span class="opacity-60">by {book.author}</span>
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
