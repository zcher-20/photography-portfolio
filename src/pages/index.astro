---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { homePageContent, identity } from "../config";
import SocialLink from "../components/SocialLink.astro";
import Link from "../components/Link.astro";
import HeroName from "../components/HeroName";
import AnimatedLink from "../components/AnimatedLink";
import { getCollection } from "astro:content";

let posts = await getCollection("posts");
posts = posts.filter((p) => !p.data?.draft);
posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
posts.splice(3)
---

<Layout seo={homePageContent.seo}>
  <section class="pt-28 pl-3 pr-10 scroll-reveal">
    <div class="text-sm leading-relaxed mb-8 space-y-4">
  <p>Welcome! I'm a junior at Columbia University studying Computer Science & Design, previously at NYU.</p>
  <p>I work on LLM's and agents with <AnimatedLink href="https://openai.com" client:idle>OpenAI</AnimatedLink> and <AnimatedLink href="https://pfizer.com" client:idle>Pfizer</AnimatedLink>, and have published research at <AnimatedLink href="https://openreview.net/forum?id=hvp5I4dDya" client:idle>ICLR 2024</AnimatedLink> and <AnimatedLink href="https://www.ijcai.org/proceedings/2024/878" client:idle>IJCAI 2024</AnimatedLink> from my time at <AnimatedLink href="https://research.ibm.com" client:idle>IBM Research</AnimatedLink>. I'm currently building AI agents at an MIT-incubated startup and collaborating with Al Akhawayn University to extend <AnimatedLink href="https://huggingface.co/ibm-nasa-geospatial/Prithvi-100M" client:idle>NASA's Prithvi foundation model</AnimatedLink> for wildfire prediction in Morocco.</p>
  <p>My passions are at the intersection of AI research, full-stack engineering, and human-centered design. Outside of work you'll find me hosting dinner parties, traveling the world, and experimenting with film photography!</p>
  <p>Recognized for research excellence through ICLR 2024, the <AnimatedLink href="https://www.zurich.ibm.com/thinklab/AIcomputesymposium.html" client:idle>IBM/IEEE AICS 2023</AnimatedLink> competition, the Best Research Award at the University of Sharjah, and finalist selections at both the Genius Olympiad and WESEF.</p>
</div>
  </section>
</Layout>
