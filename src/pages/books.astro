---
import Layout from "../layouts/Layout.astro";
import { identity } from "../config";

const BOOKS = [
  { country: "Japan", title: "Norwegian Wood", author: "Haruki Murakami", favorite: true },
  { country: "Pakistan", title: "Exit West", author: "Mohsin Hamid", favorite: true },
  { country: "Afghanistan", title: "The Kite Runner", author: "Khaled Hosseini", favorite: false },
  { country: "Turkey", title: "The Forty Rules of Love", author: "Elif Shafak", favorite: false },
  { country: "France", title: "No Exit", author: "Jean-Paul Sartre", favorite: true },
  { country: "England", title: "A Room of One's Own", author: "Virginia Woolf", favorite: true },
  { country: "Russia", title: "White Nights", author: "Fyodor Dostoyevsky", favorite: false },
  { country: "Italy", title: "The Lying Life of Adults", author: "Elena Ferrante", favorite: false },
  { country: "USA", title: "Giovanni's Room", author: "James Baldwin", favorite: true },
  { country: "Mexico", title: "The Alchemist", author: "Paulo Coelho", favorite: false },
  { country: "Brazil", title: "The Hour of the Star", author: "Clarice Lispector", favorite: true },
  { country: "Argentina", title: "The Invention of Morel", author: "Adolfo Bioy Casares", favorite: true },
  { country: "Chile", title: "The House of the Spirits", author: "Isabel Allende", favorite: false },
  { country: "Australia", title: "The Book Thief", author: "Markus Zusak", favorite: false },
];
---

<Layout
  seo={{
    title: "Books | " + identity.name,
    description: "One book per country — reading the world.",
    image: identity.logo,
  }}
>
  <section class="mt-10 max-w-2xl mx-auto px-6 scroll-reveal text-center">
    <h1 class="font-bold text-3xl mb-10">Bookshelf</h1>
  </section>

  <section id="map-container" class="books-map"></section>
  <div id="tooltip" class="books-tooltip"></div>
  <script id="books-data" type="application/json" set:html={JSON.stringify(BOOKS)} />

  <section class="max-w-2xl mx-auto px-6 text-center mt-4">
    <p class="opacity-40">Tracking my progress as I read a book from every country in the world.</p>
  </section>

  <section class="mt-16 mb-4 scroll-reveal">
    <div class="max-w-2xl mx-auto px-6 mb-6 text-center">
      <h1 class="font-bold text-3xl mb-1">Favorites</h1>
    </div>
    <div style="overflow:hidden; width:100%; position:relative;">
      <div style="position:absolute; left:0; top:0; bottom:0; width:80px; background:linear-gradient(to right, white, transparent); z-index:2; pointer-events:none;"></div>
      <div style="position:absolute; right:0; top:0; bottom:0; width:80px; background:linear-gradient(to left, white, transparent); z-index:2; pointer-events:none;"></div>
      <div id="marquee-track" style="display:flex; gap:20px; width:max-content; will-change:transform; padding: 8px 0 16px;"></div>
    </div>
  </section>

  <section class="mt-8 max-w-2xl mx-auto px-6 mb-20 scroll-reveal">
    <h1 class="font-bold text-3xl mb-6 text-center">Reading the World</h1>
    <ul class="grid grid-cols-2 gap-x-8 gap-y-3">
      {BOOKS.map((book) => (
        <li class="flex items-baseline gap-2 text-sm">
          <span class="opacity-60 shrink-0">{book.country}</span>
          <span class="opacity-30">–</span>
          <span class="font-medium">{book.title}</span>
          {book.author && <span class="opacity-60 hidden sm:inline">by {book.author}{book.favorite ? " *" : ""}</span>}
        </li>
      ))}
    </ul>
    <p class="text-xs opacity-40 mt-8">* personal favourite</p>
  </section>
</Layout>

<style is:global>
  .books-map { width: 100%; background: #fff; overflow: hidden; }
  .dark .books-map { background: #000; }
  .books-map svg { display: block; width: 100%; height: auto; }
  .books-tooltip {
    display: none; position: fixed; font-size: 11px;
    background: #fff; color: #000; padding: 8px 12px;
    pointer-events: none; z-index: 100; line-height: 1.5; border-radius: 0;
  }
</style>

<script is:inline>
  (function () {
    var FAVORITES = [
      { title: "Never Let Me Go", author: "Kazuo Ishiguro" },
      { title: "The Picture of Dorian Gray", author: "Oscar Wilde" },
      { title: "East of Eden", author: "John Steinbeck" },
      { title: "The Year of Magical Thinking", author: "Joan Didion" },
      { title: "Giovanni's Room", author: "James Baldwin" },
      { title: "Thinking, Fast and Slow", author: "Daniel Kahneman" },
      { title: "Just Kids", author: "Patti Smith" },
      { title: "Sula", author: "Toni Morrison" },
      { title: "The Invisible Life of Addie LaRue", author: "V. E. Schwab" },
      { title: "Normal People", author: "Sally Rooney" },
      { title: "Devotions", author: "Mary Oliver" },
      { title: "Walden", author: "Henry David Thoreau" },
      { title: "The Book Thief", author: "Markus Zusak" },
      { title: "All About Love", author: "bell hooks" },
      { title: "White Nights", author: "Fyodor Dostoyevsky" },
      { title: "Atonement", author: "Ian McEwan" },
      { title: "The Secret History", author: "Donna Tartt" },
    ];

    var COVERS = {
      "Never Let Me Go": "https://covers.openlibrary.org/b/isbn/1400043395-M.jpg",
      "The Picture of Dorian Gray": "https://covers.openlibrary.org/b/isbn/0141439572-M.jpg",
      "East of Eden": "https://covers.openlibrary.org/b/isbn/0142004235-M.jpg",
      "Giovanni's Room": "https://covers.openlibrary.org/b/isbn/0375701877-M.jpg",
      "Thinking, Fast and Slow": "https://covers.openlibrary.org/b/isbn/9780374533557-M.jpg",
      "Just Kids": "https://covers.openlibrary.org/b/isbn/9780060936228-M.jpg",
      "Sula": "https://covers.openlibrary.org/b/isbn/1400033438-M.jpg",
      "The Invisible Life of Addie LaRue": "https://covers.openlibrary.org/b/isbn/0765387565-M.jpg",
      "Normal People": "https://covers.openlibrary.org/b/isbn/9781984822178-M.jpg",
      "Devotions": "/devotions.jpg",
      "Walden": "https://covers.openlibrary.org/b/isbn/9780691096124-M.jpg",
      "The Year of Magical Thinking": "/magical-thinking.jpg",
      "The Book Thief": "https://covers.openlibrary.org/b/isbn/0375842209-M.jpg",
      "All About Love": "https://covers.openlibrary.org/b/isbn/0060959479-M.jpg",
      "White Nights": "https://covers.openlibrary.org/b/isbn/9780140449266-M.jpg",
      "Atonement": "https://covers.openlibrary.org/b/isbn/9780385721790-M.jpg",
      "The Secret History": "https://covers.openlibrary.org/b/isbn/1400031702-M.jpg"
    };

    var track = document.getElementById('marquee-track');
    if (!track) return;

    var all = FAVORITES.concat(FAVORITES);
    all.forEach(function (book) {
      var cover = COVERS[book.title] || '';
      var item = document.createElement('div');
      item.style.cssText = 'flex-shrink:0; width:90px; cursor:default;';
      var imgHtml = cover
        ? '<img src="' + cover + '" alt="' + book.title + '" style="width:100%; height:100%; object-fit:cover;" onerror="this.parentElement.style.background=\'#e5e7eb\'" />'
        : '<div style="display:flex;align-items:center;justify-content:center;height:100%;padding:8px;font-size:9px;text-align:center;color:#9ca3af;">' + book.title + '</div>';
      item.innerHTML =
        '<div style="width:90px; height:130px; border-radius:4px; overflow:hidden; background:#f3f4f6; margin-bottom:8px; box-shadow:0 2px 8px rgba(0,0,0,0.1);">' + imgHtml + '</div>' +
        '<p style="font-size:10px; font-weight:500; line-height:1.3; margin:0; opacity:0.8;">' + book.title + '</p>' +
        '<p style="font-size:9px; opacity:0.45; margin:2px 0 0;">' + book.author + '</p>';
      track.appendChild(item);
    });

    var x = 0;
    var paused = false;
    track.addEventListener('mouseenter', function () { paused = true; });
    track.addEventListener('mouseleave', function () { paused = false; });

    function animate() {
      if (!paused) {
        x -= 0.5;
        var half = track.scrollWidth / 2;
        if (Math.abs(x) >= half) x = 0;
        track.style.transform = 'translateX(' + x + 'px)';
      }
      requestAnimationFrame(animate);
    }
    animate();
  })();
</script>

<script>
  import * as d3 from "d3";

  interface Book { country: string; title: string; author: string; favorite: boolean; }
  const BOOKS: Book[] = JSON.parse(document.getElementById("books-data")!.textContent!);
  const bookMap = new Map(BOOKS.map((b) => [b.country, b]));
  const container = document.getElementById("map-container") as HTMLDivElement;
  const tooltip = document.getElementById("tooltip") as HTMLDivElement;
  let geoData: any = null;

  async function render() {
    const width = container.clientWidth;
    const height = width * 0.5;
    container.innerHTML = "";
    const svg = d3.select(container).append("svg").attr("width", width).attr("height", height);
    if (!geoData) {
      const response = await fetch("/world.geojson");
      geoData = await response.json();
    }
    const projection = d3.geoNaturalEarth1().fitSize([width, height], geoData);
    const path = d3.geoPath().projection(projection);
    const isDark = document.documentElement.classList.contains("dark");
    const readColor = isDark ? "#ffffff" : "#B89EA9";
    const unreadColor = isDark ? "#1a1a1a" : "#e5e7eb";
    const glowFilter = isDark ? "drop-shadow(0 0 6px rgba(255,255,255,0.4))" : "drop-shadow(0 0 6px rgba(184,158,169,0.5))";

    svg.selectAll("path").data(geoData.features).join("path")
      .attr("d", path as any)
      .attr("fill", (d: any) => bookMap.has(d.properties.name) ? readColor : unreadColor)
      .attr("stroke", "none")
      .style("filter", (d: any) => bookMap.has(d.properties.name) ? glowFilter : "none")
      .style("cursor", (d: any) => bookMap.has(d.properties.name) ? "pointer" : "default")
      .on("mouseenter", function (_event: MouseEvent, d: any) {
        const book = bookMap.get(d.properties.name);
        if (!book) return;
        tooltip.style.display = "block";
        tooltip.innerHTML = "<strong>" + book.country + "</strong><br/>" + book.title + "<br/><em>" + book.author + "</em>";
      })
      .on("mousemove", function (event: MouseEvent) {
        tooltip.style.left = event.clientX + 12 + "px";
        tooltip.style.top = event.clientY + 12 + "px";
      })
      .on("mouseleave", function () { tooltip.style.display = "none"; });
  }

  render();
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(render, 200);
  });

  new MutationObserver(() => render()).observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });
</script>