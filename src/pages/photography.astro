---
import Layout from "../layouts/Layout.astro";
import { identity } from "../config";

const PHOTOS = [
  "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=600&q=80",
  "https://images.unsplash.com/photo-1501854140801-50d01698950b?w=600&q=80",
  "https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?w=600&q=80",
  "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=600&q=80",
  "https://images.unsplash.com/photo-1518173946687-a4c8892bbd9f?w=600&q=80",
  "https://images.unsplash.com/photo-1490730141103-6cac27aaab94?w=600&q=80",
  "https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?w=600&q=80",
  "https://images.unsplash.com/photo-1504700610630-ac6aba3536d3?w=600&q=80",
  "https://images.unsplash.com/photo-1465146344425-f00d5f5c8f07?w=600&q=80",
  "https://images.unsplash.com/photo-1500375592092-40eb2168fd21?w=600&q=80",
  "https://images.unsplash.com/photo-1510784722466-f2aa240d2699?w=600&q=80",
  "https://images.unsplash.com/photo-1426604966848-d7adac402bff?w=600&q=80",
];
---

<Layout
  seo={{
    title: "Photography | " + identity.name,
    description: "Photography by Zayneb Cherif.",
    image: identity.logo,
  }}
>
  <!-- Trail section -->
  <section
    id="trail-section"
    style="position:relative; width:100%; height:90vh; overflow:hidden; cursor:crosshair; background:#fff;"
  >
    <h1
      id="photo-title"
      style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:clamp(3rem,10vw,7rem); font-weight:700; letter-spacing:-0.03em; color:#111; pointer-events:none; z-index:10; white-space:nowrap; transition:opacity 0.4s; user-select:none;"
    >Photography</h1>
    
  </section>

  <!-- Gallery marquee section -->
  <section class="mt-16 mb-4 scroll-reveal">
    <div class="max-w-2xl mx-auto px-6 mb-6 text-center">
      <h1 class="font-bold text-3xl mb-1">Morocco</h1>
    </div>
    <div style="overflow:hidden; width:100%; position:relative;">
      <div style="position:absolute; left:0; top:0; bottom:0; width:80px; background:linear-gradient(to right, white, transparent); z-index:2; pointer-events:none;"></div>
      <div style="position:absolute; right:0; top:0; bottom:0; width:80px; background:linear-gradient(to left, white, transparent); z-index:2; pointer-events:none;"></div>
      <div id="gallery-track" style="display:flex; gap:12px; width:max-content; will-change:transform; padding:8px 0 16px;"></div>
    </div>
  </section>


  <!-- Spain marquee section -->
  <section class="mt-16 mb-4 scroll-reveal">
    <div class="max-w-2xl mx-auto px-6 mb-6 text-center">
      <h1 class="font-bold text-3xl mb-1">Spain</h1>
    </div>
    <div style="overflow:hidden; width:100%; position:relative;">
      <div style="position:absolute; left:0; top:0; bottom:0; width:80px; background:linear-gradient(to right, white, transparent); z-index:2; pointer-events:none;"></div>
      <div style="position:absolute; right:0; top:0; bottom:0; width:80px; background:linear-gradient(to left, white, transparent); z-index:2; pointer-events:none;"></div>
      <div id="spain-track" style="display:flex; gap:12px; width:max-content; will-change:transform; padding:8px 0 16px;"></div>
    </div>
  </section>


  <!-- Switzerland marquee section -->
  <section class="mt-16 mb-4 scroll-reveal">
    <div class="max-w-2xl mx-auto px-6 mb-6 text-center">
      <h1 class="font-bold text-3xl mb-1">Switzerland</h1>
    </div>
    <div style="overflow:hidden; width:100%; position:relative;">
      <div style="position:absolute; left:0; top:0; bottom:0; width:80px; background:linear-gradient(to right, white, transparent); z-index:2; pointer-events:none;"></div>
      <div style="position:absolute; right:0; top:0; bottom:0; width:80px; background:linear-gradient(to left, white, transparent); z-index:2; pointer-events:none;"></div>
      <div id="switzerland-track" style="display:flex; gap:12px; width:max-content; will-change:transform; padding:8px 0 16px;"></div>
    </div>
  </section>

  <div class="mb-20"></div>

</Layout>

<script is:inline>
  (function () {
    // Trail effect
        var PHOTOS = [
      "/photography/trail/100_1775.JPG",
      "/photography/trail/IMG_0005.JPG",
      "/photography/trail/IMG_0064.JPG",
      "/photography/trail/IMG_0145.jpeg",
      "/photography/trail/IMG_0667.jpeg",
      "/photography/trail/IMG_0840.JPG",
      "/photography/trail/IMG_0858.JPG",
      "/photography/trail/IMG_0858.jpeg",
      "/photography/trail/IMG_1176.JPG",
      "/photography/trail/IMG_2675.jpeg",
      "/photography/trail/IMG_3857.jpeg",
      "/photography/trail/IMG_6484.jpeg",
      "/photography/trail/IMG_6875.jpeg",
      "/photography/trail/IMG_8531.jpeg",
      "/photography/trail/IMG_9023.jpeg",
      "/photography/trail/IMG_9108.jpeg",
      "/photography/trail/IMG_9553.JPG",
      "/photography/trail/IMG_9863.jpeg",
      "/photography/trail/Tezza-5653.jpg"
    ];

    // Preload trail images so they appear instantly on hover
    PHOTOS.forEach(function(src) { var i = new Image(); i.src = src; });

    var section = document.getElementById('trail-section');
    var title = document.getElementById('photo-title');
    if (!section || !title) return;

    var lastX = 0;
    var lastY = 0;
    var photoIndex = 0;
    var threshold = 80;
    var distAccum = 0;
    var moveTimeout = 0;

    section.addEventListener('mousemove', function (e) {
      var rect = section.getBoundingClientRect();
      var mouseX = e.clientX - rect.left;
      var mouseY = e.clientY - rect.top;
      var dx = mouseX - lastX;
      var dy = mouseY - lastY;
      distAccum += Math.sqrt(dx * dx + dy * dy);

      title.style.opacity = '0.06';
      clearTimeout(moveTimeout);
      moveTimeout = window.setTimeout(function () {
        title.style.opacity = '1';
      }, 1500);

      if (distAccum >= threshold) {
        distAccum = 0;
        spawnPhoto(mouseX, mouseY);
      }

      lastX = mouseX;
      lastY = mouseY;
    });

    section.addEventListener('mouseleave', function () {
      title.style.opacity = '1';
    });

    function spawnPhoto(x, y) {
      var img = document.createElement('img');
      img.decoding = 'async';
      img.src = PHOTOS[photoIndex % PHOTOS.length];
      photoIndex++;
      var w = 110 + Math.random() * 70;
      var h = w * (0.65 + Math.random() * 0.5);
      var rotate = (Math.random() - 0.5) * 18;
      img.style.cssText = 'position:absolute;left:' + (x - w/2) + 'px;top:' + (y - h/2) + 'px;width:' + w + 'px;height:' + h + 'px;object-fit:cover;border-radius:2px;pointer-events:none;transform:rotate(' + rotate + 'deg) scale(0.85);opacity:0;transition:opacity 0.15s ease,transform 0.15s ease;z-index:5;';
      section.appendChild(img);
      requestAnimationFrame(function () {
        img.style.opacity = '1';
        img.style.transform = 'rotate(' + rotate + 'deg) scale(1)';
      });
      setTimeout(function () {
        img.style.opacity = '0';
        img.style.transform = 'rotate(' + rotate + 'deg) scale(1.08)';
        setTimeout(function () { img.remove(); }, 500);
      }, 1800);
    }

    // Gallery marquee
        var GALLERY = [
      "/photography/morocco/98586D38-38FC-4F70-BCAF-1A20B19D7947.jpeg",
      "/photography/morocco/IMG_3049.PNG",
      "/photography/morocco/IMG_7172.jpeg",
      "/photography/morocco/IMG_8971.jpeg",
      "/photography/morocco/IMG_9150.jpeg",
      "/photography/morocco/IMG_9172.jpeg",
      "/photography/morocco/IMG_9295.jpeg",
      "/photography/morocco/IMG_9553.JPG",
      "/photography/morocco/Tezza-5653.jpg"
    ];

    var track = document.getElementById('gallery-track');
    if (!track) return;

    var all = GALLERY.concat(GALLERY);
    all.forEach(function (src) {
      var item = document.createElement('div');
      item.style.cssText = 'flex-shrink:0; width:200px; height:140px; overflow:hidden; border-radius:4px;';
      var img = document.createElement('img');
      img.src = src;
      img.loading = 'lazy';
      img.decoding = 'async';
      img.style.cssText = 'width:100%; height:100%; object-fit:cover;';
      item.appendChild(img);
      track.appendChild(item);
    });

    var gx = 0;
    var gPaused = false;
    track.addEventListener('mouseenter', function () { gPaused = true; });
    track.addEventListener('mouseleave', function () { gPaused = false; });

    function animateGallery() {
      if (!gPaused) {
        gx -= 0.6;
        var half = track.scrollWidth / 2;
        if (Math.abs(gx) >= half) gx = 0;
        track.style.transform = 'translateX(' + gx + 'px)';
      }
      requestAnimationFrame(animateGallery);
    }
    animateGallery();

    // Spain marquee
    var SPAIN = [
      "/photography/spain/IMG_1036.JPG",
      "/photography/spain/IMG_1065.JPG",
      "/photography/spain/IMG_3242.jpeg",
      "/photography/spain/IMG_5296.jpeg",
      "/photography/spain/IMG_5336.jpeg",
      "/photography/spain/IMG_5660.JPG",
      "/photography/spain/IMG_6780.jpeg",
      "/photography/spain/IMG_6797.JPG"
    ];
    var spainTrack = document.getElementById('spain-track');
    if (spainTrack) {
      var spainAll = SPAIN.concat(SPAIN);
      spainAll.forEach(function (src) {
        var item = document.createElement('div');
        item.style.cssText = 'flex-shrink:0; width:200px; height:140px; overflow:hidden; border-radius:4px;';
        var img = document.createElement('img');
        img.src = src;
        img.loading = 'lazy';
        img.decoding = 'async';
        img.style.cssText = 'width:100%; height:100%; object-fit:cover;';
        item.appendChild(img);
        spainTrack.appendChild(item);
      });
      var sx = 0;
      var sPaused = false;
      spainTrack.addEventListener('mouseenter', function () { sPaused = true; });
      spainTrack.addEventListener('mouseleave', function () { sPaused = false; });
      function animateSpain() {
        if (!sPaused) {
          sx -= 0.6;
          var half = spainTrack.scrollWidth / 2;
          if (Math.abs(sx) >= half) sx = 0;
          spainTrack.style.transform = 'translateX(' + sx + 'px)';
        }
        requestAnimationFrame(animateSpain);
      }
      animateSpain();
    }

    // Switzerland marquee
    var SWITZERLAND = [
      "/photography/switzerland/A9CAAB5F-644C-4EA6-96E6-193BB256629B.jpeg",
      "/photography/switzerland/IMG_0403.JPG",
      "/photography/switzerland/IMG_0435.jpeg",
      "/photography/switzerland/IMG_0913.jpeg",
      "/photography/switzerland/IMG_1154.jpeg",
      "/photography/switzerland/IMG_1414.jpeg",
      "/photography/switzerland/IMG_1551.jpeg",
      "/photography/switzerland/IMG_1661.jpeg",
      "/photography/switzerland/IMG_1857.jpeg",
      "/photography/switzerland/IMG_2243.jpeg",
      "/photography/switzerland/IMG_2261.jpeg",
      "/photography/switzerland/IMG_2707.PNG",
      "/photography/switzerland/IMG_9831.jpeg"
    ];
    var swissTrack = document.getElementById('switzerland-track');
    if (swissTrack) {
      var swissAll = SWITZERLAND.concat(SWITZERLAND);
      swissAll.forEach(function (src) {
        var item = document.createElement('div');
        item.style.cssText = 'flex-shrink:0; width:200px; height:140px; overflow:hidden; border-radius:4px;';
        var img = document.createElement('img');
        img.src = src;
        img.loading = 'lazy';
        img.decoding = 'async';
        img.style.cssText = 'width:100%; height:100%; object-fit:cover;';
        item.appendChild(img);
        swissTrack.appendChild(item);
      });
      var wx = 0;
      var wPaused = false;
      swissTrack.addEventListener('mouseenter', function () { wPaused = true; });
      swissTrack.addEventListener('mouseleave', function () { wPaused = false; });
      function animateSwitzerland() {
        if (!wPaused) {
          wx -= 0.6;
          var half = swissTrack.scrollWidth / 2;
          if (Math.abs(wx) >= half) wx = 0;
          swissTrack.style.transform = 'translateX(' + wx + 'px)';
        }
        requestAnimationFrame(animateSwitzerland);
      }
      animateSwitzerland();
    }
  })();
</script>
