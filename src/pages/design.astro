---
import Layout from "../layouts/Layout.astro";
import { identity } from "../config";
---

<Layout
  seo={{
    title: "Design | " + identity.name,
    description: "Design projects by Zayneb Cherif.",
    image: identity.logo,
  }}
>
  <section class="pt-20 pl-3 pr-10 scroll-reveal">

    <!-- Project 01: Are.na Visualizer -->
    <div class="design-row">
      <div class="design-index">( &nbsp; 01. &nbsp; . &nbsp; )</div>
      <div class="design-image">
        <a href="https://arena-vis.vercel.app" target="_blank">
          <img src="/design-arena-vis-v2.png" alt="Are.na Visualizer" />
        </a>
      </div>
      <div class="design-category">DESIGN WORK</div>
      <div class="design-info">
        <p class="design-desc">A visual explorer for Are.na channels, built to browse collections across multiple layout modes including grid, canvas, and disk views. Built with Tailwind CSS, Are.na API, TypeScript 5, React 19, Next.js 16, and deployed on Vercel.</p>
        <a href="https://arena-vis.vercel.app" target="_blank" class="design-link">Link &rarr;</a>
      </div>
    </div>

    <hr class="design-divider" />

    <!-- Project 02: Maison Margiela Archive -->
    <div class="design-row">
      <div class="design-index">( &nbsp; 02. &nbsp; . &nbsp; )</div>
      <div class="design-image">
        <a href="https://margiela-archive.vercel.app/" target="_blank">
          <img src="/design-margiela.png" alt="Maison Margiela Archive" />
        </a>
      </div>
      <div class="design-category">ART DIRECTION</div>
      <div class="design-info">
        <p class="design-desc">A visual archive of the Maison Margiela folders. Browsable gallery with a scrolling filmstrip, rotated hero image, and editorial layout. Built with Next.js, React, TypeScript, and deployed on Vercel.</p>
        <a href="https://margiela-archive.vercel.app/" target="_blank" class="design-link">Link &rarr;</a>
      </div>
    </div>

    <hr class="design-divider" />

    <!-- Project 03: Film Archive -->
    <div class="design-row">
      <div class="design-index">( &nbsp; 03. &nbsp; . &nbsp; )</div>
      <div class="design-image">
        <a href="https://github.com/zcher-20/Film-Album" target="_blank">
          <img src="/design-film-album.png" alt="Film Archive" />
        </a>
      </div>
      <div class="design-category">INTERACTIVE DESIGN</div>
      <div class="design-info">
        <p class="design-desc">An interactive, scroll-driven photo gallery built with vanilla JavaScript. A single self-contained HTML file featuring a continuous depth-based carousel, real-time caption editing, and full client-side persistence via IndexedDB.</p>
        <a href="https://github.com/zcher-20/Film-Album" target="_blank" class="design-link">Link &rarr;</a>
      </div>
    </div>

  </section>
</Layout>

<style>
  .design-row {
    display: grid;
    grid-template-columns: 80px 300px 180px 1fr;
    gap: 24px;
    align-items: start;
    padding: 40px 0;
  }

  .design-index {
    font-size: 12px;
    opacity: 0.4;
    white-space: nowrap;
    padding-top: 4px;
  }

  .design-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .design-image a {
    display: block;
  }

  .design-image a:hover img {
    opacity: 0.9;
    transition: opacity 0.2s;
  }

  .design-category {
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.05em;
    padding-top: 4px;
  }

  .design-desc {
    font-size: 11px;
    line-height: 1.7;
    letter-spacing: 0.02em;
    margin-bottom: 16px;
  }

  .design-link {
    font-size: 12px;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.8;
  }

  .design-link:hover {
    opacity: 1;
  }

  .design-divider {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    margin: 0;
  }
</style>
