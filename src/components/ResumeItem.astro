---
import { Image } from "astro:assets";
import type { ResumeItem } from "../types/config";

type Props = ResumeItem;

const { title, company, date, description } = Astro.props;
---

<div class="py-4 border-b border-gray-200 dark:border-gray-900 last:border-b-0">
  <div class="flex items-start justify-between">
    <div class="flex items-start gap-4 flex-1">
      <a href={company.url} target="_blank" rel="noopener noreferrer" class="shrink-0">
        <Image
          src={company.image}
          alt={company.name}
          width={40}
          height={40}
          class="rounded-full w-[40px] h-[40px] object-cover mt-1 hover:opacity-80 transition-opacity"
        />
      </a>
      <div class="flex-1">
        <a href={company.url} target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity">
          <h3 class="font-medium text-lg">{title}</h3>
          <p class="text-sm opacity-60 mb-2">{company.name}</p>
        </a>
        {description && (
          <p class="text-sm opacity-80 leading-relaxed resume-desc" set:html={description} />
        )}
      </div>
    </div>
    <p class="text-sm opacity-60 ml-4 mt-1">{date}</p>
  </div>
</div>

<style>
  .resume-desc :global(a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(0, 0, 0, 0.25);
    position: relative;
  }
  :global(.dark) .resume-desc :global(a) {
    text-decoration-color: rgba(255, 255, 255, 0.3);
  }
</style>

<style is:global>
  .link-preview {
    position: fixed;
    z-index: 1000;
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 6px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    padding: 10px 14px;
    pointer-events: none;
    max-width: 260px;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .link-preview.visible { opacity: 1; }
  .dark .link-preview {
    background: #1a1a1a;
    border-color: #333;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }
  .link-preview-domain {
    font-size: 10px;
    opacity: 0.4;
    margin-bottom: 3px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .link-preview-title {
    font-size: 12px;
    font-weight: 500;
    line-height: 1.4;
  }
  .link-preview-url {
    font-size: 10px;
    opacity: 0.35;
    margin-top: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>

<script is:inline>
  (function() {
    if (document.getElementById('link-preview-el')) return;

    var preview = document.createElement('div');
    preview.id = 'link-preview-el';
    preview.className = 'link-preview';
    preview.innerHTML = '<div class="link-preview-domain"></div><div class="link-preview-title"></div><div class="link-preview-url"></div>';
    document.body.appendChild(preview);

    var timer = null;

    document.addEventListener('mouseover', function(e) {
      var link = e.target.closest('.resume-desc a');
      if (!link) return;

      clearTimeout(timer);
      try {
        var url = new URL(link.href);
        var domain = url.hostname.replace('www.', '');
        var text = link.textContent.trim();
        var path = url.pathname.length > 1 ? url.pathname : '';

        preview.querySelector('.link-preview-domain').textContent = domain;
        preview.querySelector('.link-preview-title').textContent = text;
        preview.querySelector('.link-preview-url').textContent = path ? domain + path : domain;

        var rect = link.getBoundingClientRect();
        preview.style.left = Math.min(rect.left, window.innerWidth - 280) + 'px';
        preview.style.top = (rect.bottom + 8) + 'px';
        preview.classList.add('visible');
      } catch(err) {}
    });

    document.addEventListener('mouseout', function(e) {
      var link = e.target.closest('.resume-desc a');
      if (!link) return;
      timer = setTimeout(function() {
        preview.classList.remove('visible');
      }, 100);
    });
  })();
</script>
