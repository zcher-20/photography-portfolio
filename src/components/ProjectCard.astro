---
import { Image } from "astro:assets";
import type { Project } from "../types/config";
import {marked} from "marked"

type Props = Project;

const { title, description, image, year, url, demoUrl, pdfUrl, tags, venue } = Astro.props;
const htmlDescription = marked.parse(description);
const cardId = Math.random().toString(36).slice(2, 8);
---

<div class="sm:py-5 py-10 flex flex-col gap-6 group-hover:opacity-60 hover:!opacity-100 transition-opacity project-card-wrap" style="position:relative;">
  <div
    id={`trigger-${cardId}`}
    class="w-full bg-gray-200 dark:bg-gray-700 rounded-lg aspect-video block overflow-hidden cursor-zoom-in"
  >
    {pdfUrl ? (
      <div class="w-full h-full flex items-center justify-center bg-gray-100 dark:bg-gray-800 rounded-lg">
        <div class="text-center opacity-50">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <p style="font-size:11px; margin-top:6px;">Click to view PDF</p>
        </div>
      </div>
    ) : (
      <Image
        width={1920}
        height={1080}
        src={image}
        alt={title}
        class="w-full h-full object-cover rounded-lg aspect-video"
      />
    )}
  </div>
  <div class="flex-1">
    <div class="flex items-center gap-1 mb-2">
      <span
        id={`hover-trigger-${cardId}`}
        class="font-medium cursor-default hover:underline underline-offset-2"
        style="text-decoration-color: rgba(0,0,0,0.3);"
      >{title}</span>
      {year && <span class="opacity-60">· {year}</span>}
    </div>
    <div class="opacity-60">
      <Fragment set:html={htmlDescription} />
      {demoUrl && (
        <span>
          {" "}
          <a href={demoUrl} target="_blank" class="text-blue-600 hover:text-blue-500 dark:text-blue-400 dark:hover:text-blue-300 underline">
            See demo
          </a>
        </span>
      )}
    </div>
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-3">
        {tags.map((tag) => (
          <span style="font-size:11px; padding:2px 8px; background:#f3f4f6; border-radius:999px; color:#6b7280;">{tag}</span>
        ))}
      </div>
    )}
  </div>

  <!-- Hovercard -->
  <div
    id={`hovercard-${cardId}`}
    style="display:none; position:absolute; left:calc(100% + 16px); top:0; width:280px; background:#fff; border:1px solid #e5e7eb; border-radius:10px; box-shadow:0 8px 30px rgba(0,0,0,0.1); padding:20px; z-index:100; pointer-events:auto;"
  >
    {image && !pdfUrl && (
      <img
        src={image}
        alt={title}
        style="width:100%; height:140px; object-fit:cover; border-radius:6px; margin-bottom:14px;"
      />
    )}
    <p style="font-size:13px; font-weight:600; margin:0 0 4px; color:#111;">{title}</p>
    {venue && (
      <p style="font-size:11px; color:#8b1a4a; margin:0 0 12px; font-weight:500;">{venue}</p>
    )}
    {tags && tags.length > 0 && (
      <div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:14px;">
        {tags.map((tag) => (
          <span style="font-size:10px; padding:2px 8px; background:#f3f4f6; border-radius:999px; color:#6b7280;">{tag}</span>
        ))}
      </div>
    )}
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      <a
        href={url}
        target="_blank"
        style="font-size:11px; padding:5px 12px; background:#111; color:#fff; border-radius:6px; text-decoration:none; font-weight:500;"
      >{pdfUrl || url.includes('openreview') || url.includes('ijcai') ? 'Read paper →' : 'GitHub →'}</a>
      {demoUrl && (
        <a
          href={demoUrl}
          target="_blank"
          style="font-size:11px; padding:5px 12px; background:#f3f4f6; color:#374151; border-radius:6px; text-decoration:none; font-weight:500;"
        >Demo →</a>
      )}
    </div>
  </div>
</div>

<!-- Lightbox -->
<div
  id={`lightbox-${cardId}`}
  style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.88); z-index:9999; align-items:center; justify-content:center;"
>
  <div
    id={`card-${cardId}`}
    style="position:relative; width:min(90vw,920px); height:85vh; background:#fff; border-radius:12px; overflow:hidden; display:flex; flex-direction:column; box-shadow:0 30px 80px rgba(0,0,0,0.5);"
    onclick="event.stopPropagation()"
  >
    <button
      id={`close-${cardId}`}
      style="position:absolute; top:12px; right:14px; z-index:10; background:rgba(0,0,0,0.12); border:none; border-radius:50%; width:32px; height:32px; cursor:pointer; font-size:16px; display:flex; align-items:center; justify-content:center; color:#333;"
    >✕</button>

    {pdfUrl ? (
      <div style="flex:1; display:flex; flex-direction:column; overflow:hidden;">
        <div style="flex:1; overflow:hidden; display:flex; align-items:center; justify-content:center; background:#f5f5f5; padding:16px;">
          <canvas id={`pdf-canvas-${cardId}`} style="max-width:100%; max-height:100%; object-fit:contain; box-shadow:0 4px 20px rgba(0,0,0,0.15);"></canvas>
        </div>
        <div style="height:56px; display:flex; align-items:center; justify-content:center; gap:24px; border-top:1px solid #eee; flex-shrink:0; background:#fff;">
          <button id={`prev-${cardId}`} style="background:none; border:1px solid #ddd; border-radius:6px; padding:6px 16px; cursor:pointer; font-size:14px; color:#444;">←</button>
          <span id={`page-info-${cardId}`} style="font-size:13px; opacity:0.5; min-width:60px; text-align:center;">1 / ?</span>
          <button id={`next-${cardId}`} style="background:none; border:1px solid #ddd; border-radius:6px; padding:6px 16px; cursor:pointer; font-size:14px; color:#444;">→</button>
        </div>
      </div>
    ) : (
      <div style="flex:1; display:flex; align-items:center; justify-content:center; padding:16px; background:#fff; overflow:hidden;">
        <img src={image} alt={title} style="max-width:100%; max-height:100%; object-fit:contain;" />
      </div>
    )}
  </div>
</div>

<script define:vars={{ cardId, pdfUrl }}>
  const trigger     = document.getElementById('trigger-' + cardId);
  const hoverTrig   = document.getElementById('hover-trigger-' + cardId);
  const hovercard   = document.getElementById('hovercard-' + cardId);
  const lightbox    = document.getElementById('lightbox-' + cardId);
  const closeBtn    = document.getElementById('close-' + cardId);
  const wrap        = hovercard?.closest('.project-card-wrap');

  // Hovercard logic
  let hideTimer = null;

  function showHover() {
    clearTimeout(hideTimer);
    if (hovercard && window.innerWidth > 768) hovercard.style.display = 'block';
  }

  function hideHover() {
    hideTimer = setTimeout(() => {
      if (hovercard) hovercard.style.display = 'none';
    }, 150);
  }

  hoverTrig?.addEventListener('mouseenter', showHover);
  hoverTrig?.addEventListener('mouseleave', hideHover);
  hovercard?.addEventListener('mouseenter', showHover);
  hovercard?.addEventListener('mouseleave', hideHover);

  // Lightbox logic
  function openLightbox() {
    lightbox.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    if (pdfUrl) initPdf();
  }

  function closeLightbox() {
    lightbox.style.display = 'none';
    document.body.style.overflow = '';
  }

  trigger?.addEventListener('click', openLightbox);
  lightbox?.addEventListener('click', closeLightbox);
  closeBtn?.addEventListener('click', (e) => { e.stopPropagation(); closeLightbox(); });

  document.addEventListener('keydown', (e) => {
    if (lightbox?.style.display === 'flex') {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight' && pdfUrl) nextPage();
      if (e.key === 'ArrowLeft' && pdfUrl) prevPage();
    }
  });

  let pdfDoc = null;
  let currentPage = 1;
  let rendering = false;
  let pdfInitialized = false;

  async function initPdf() {
    if (pdfInitialized) return;
    pdfInitialized = true;
    await new Promise((resolve) => {
      if (window.pdfjsLib) { resolve(); return; }
      const script = document.createElement('script');
      script.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
      script.onload = () => resolve();
      document.head.appendChild(script);
    });
    const pdfjsLib = window.pdfjsLib;
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    pdfDoc = await pdfjsLib.getDocument(pdfUrl).promise;
    updatePageInfo();
    renderPage(1);
  }

  function updatePageInfo() {
    const info = document.getElementById('page-info-' + cardId);
    if (info && pdfDoc) info.textContent = currentPage + ' / ' + pdfDoc.numPages;
  }

  async function renderPage(num) {
    if (!pdfDoc || rendering) return;
    rendering = true;
    const page = await pdfDoc.getPage(num);
    const canvas = document.getElementById('pdf-canvas-' + cardId);
    const container = canvas.parentElement;
    const scale = Math.min(
      (container.clientWidth - 32) / page.getViewport({ scale: 1 }).width,
      (container.clientHeight - 32) / page.getViewport({ scale: 1 }).height
    );
    const viewport = page.getViewport({ scale });
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
    rendering = false;
    updatePageInfo();
  }

  function nextPage() {
    if (pdfDoc && currentPage < pdfDoc.numPages) { currentPage++; renderPage(currentPage); }
  }

  function prevPage() {
    if (pdfDoc && currentPage > 1) { currentPage--; renderPage(currentPage); }
  }

  document.getElementById('next-' + cardId)?.addEventListener('click', (e) => { e.stopPropagation(); nextPage(); });
  document.getElementById('prev-' + cardId)?.addEventListener('click', (e) => { e.stopPropagation(); prevPage(); });
</script>
