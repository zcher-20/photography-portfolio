---
import { Image } from "astro:assets";
import type { Project } from "../types/config";
import {marked} from "marked"

type Props = Project;

const { title, description, image, year, url, demoUrl, pdfUrl, tags, venue, skills, learnings, focus, links: projectLinks } = Astro.props;
const htmlDescription = marked.parse(description);
const cardId = Math.random().toString(36).slice(2, 8);
const displaySkills = skills || tags || [];
const linkLabel = pdfUrl || url.includes('openreview') || url.includes('ijcai') ? 'Read paper' : 'GitHub';
---

<div class="py-6 sm:py-8 flex flex-col sm:flex-row gap-5 sm:gap-8 group-hover:opacity-60 hover:!opacity-100 transition-opacity project-card-wrap" style="position:relative;">
  <div
    id={`trigger-${cardId}`}
    class="w-full sm:w-[38%] flex-shrink-0 rounded-lg aspect-video sm:aspect-[4/3] overflow-hidden cursor-zoom-in"
    style="background:#f5f5f7;"
  >
    {pdfUrl ? (
      <div class="w-full h-full flex items-center justify-center rounded-lg" style="background:#fafafa;">
        <div class="text-center" style="opacity:0.35;">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <p style="font-size:10px; margin-top:4px;">PDF</p>
        </div>
      </div>
    ) : (
      <Image
        width={1920}
        height={1080}
        src={image}
        alt={title}
        class="w-full h-full object-cover rounded-lg"
      />
    )}
  </div>

  <div class="flex-1 flex flex-col justify-center min-w-0">
    <div class="flex items-baseline gap-2 mb-1">
      <span
        id={`hover-trigger-${cardId}`}
        class="font-semibold cursor-default"
        style="font-size:15px;"
      >{title}</span>
      {year && <span style="font-size:12px; opacity:0.4;">{year}</span>}
    </div>

    {venue && (
      <p style="font-size:11px; opacity:0.45; margin:0 0 8px; letter-spacing:0.01em;">{venue}</p>
    )}

    <div style="font-size:13px; opacity:0.55; line-height:1.6; margin-bottom:12px;">
      <Fragment set:html={htmlDescription} />
    </div>

    {displaySkills.length > 0 && (
      <div style="display:flex; flex-wrap:wrap; gap:6px;">
        {displaySkills.map((s) => (
          <span class="skill-box">{s}</span>
        ))}
      </div>
    )}
  </div>

  <!-- Hovercard -->
  <div
    id={`hovercard-${cardId}`}
    class="project-hovercard"
    style="display:none;"
  >
    <p style="font-size:12px; color:#111; margin:0 0 8px; font-weight:700;">Behind the project</p>
    {learnings && (
      <p style="font-size:12px; color:#333; margin:0 0 12px; line-height:1.5;">{learnings}</p>
    )}
    {focus && focus.length > 0 && (
      <div style="margin-bottom:12px;">
        <p style="font-size:12px; color:#111; margin:0 0 6px; font-weight:700;">Focus</p>
        <ul style="margin:0; padding:0; list-style:none;">
          {focus.map((f) => (
            <li style="font-size:11px; color:#555; padding:2px 0;">&ndash; {f}</li>
          ))}
        </ul>
      </div>
    )}
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      <a
        href={url}
        target="_blank"
        class="hovercard-link-primary"
      >{linkLabel} &rarr;</a>
      {demoUrl && (
        <a
          href={demoUrl}
          target="_blank"
          class="hovercard-link-secondary"
        >Demo &rarr;</a>
      )}
    </div>
  </div>
</div>

<!-- Lightbox -->
<div
  id={`lightbox-${cardId}`}
  style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.88); z-index:9999; align-items:center; justify-content:center;"
>
  <div
    id={`card-${cardId}`}
    style="position:relative; width:min(90vw,920px); height:85vh; background:#fff; border-radius:12px; overflow:hidden; display:flex; flex-direction:column; box-shadow:0 30px 80px rgba(0,0,0,0.5);"
    onclick="event.stopPropagation()"
  >
    <button
      id={`close-${cardId}`}
      style="position:absolute; top:12px; right:14px; z-index:10; background:rgba(0,0,0,0.12); border:none; border-radius:50%; width:32px; height:32px; cursor:pointer; font-size:16px; display:flex; align-items:center; justify-content:center; color:#333;"
    >&times;</button>

    {pdfUrl ? (
      <div style="flex:1; display:flex; flex-direction:column; overflow:hidden;">
        <div style="flex:1; overflow:hidden; display:flex; align-items:center; justify-content:center; background:#f5f5f5; padding:16px;">
          <canvas id={`pdf-canvas-${cardId}`} style="max-width:100%; max-height:100%; object-fit:contain; box-shadow:0 4px 20px rgba(0,0,0,0.15);"></canvas>
        </div>
        <div style="height:56px; display:flex; align-items:center; justify-content:center; gap:24px; border-top:1px solid #eee; flex-shrink:0; background:#fff;">
          <button id={`prev-${cardId}`} style="background:none; border:1px solid #ddd; border-radius:6px; padding:6px 16px; cursor:pointer; font-size:14px; color:#444;">&larr;</button>
          <span id={`page-info-${cardId}`} style="font-size:13px; opacity:0.5; min-width:60px; text-align:center;">1 / ?</span>
          <button id={`next-${cardId}`} style="background:none; border:1px solid #ddd; border-radius:6px; padding:6px 16px; cursor:pointer; font-size:14px; color:#444;">&rarr;</button>
        </div>
      </div>
    ) : (
      <div style="flex:1; display:flex; align-items:center; justify-content:center; padding:16px; background:#fff; overflow:hidden;">
        <img src={image} alt={title} style="max-width:100%; max-height:100%; object-fit:contain;" />
      </div>
    )}
  </div>
</div>

<style>
  .skill-box {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 3px 8px;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 3px;
    background: transparent;
    color: #6b7280;
    font-family: inherit;
    line-height: 1.4;
  }

  .project-hovercard {
    position: absolute;
    left: calc(100% + 16px);
    top: 0;
    width: 260px;
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    padding: 18px;
    z-index: 100;
    pointer-events: auto;
  }

  .hovercard-link-primary {
    font-size: 10px;
    padding: 4px 10px;
    border: 1px solid #222;
    color: #222;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hovercard-link-secondary {
    font-size: 10px;
    padding: 4px 10px;
    border: 1px solid #d1d5db;
    color: #6b7280;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
</style>

<script define:vars={{ cardId, pdfUrl }}>
  const trigger     = document.getElementById('trigger-' + cardId);
  const hoverTrig   = document.getElementById('hover-trigger-' + cardId);
  const hovercard   = document.getElementById('hovercard-' + cardId);
  const lightbox    = document.getElementById('lightbox-' + cardId);
  const closeBtn    = document.getElementById('close-' + cardId);

  // Hovercard logic
  let hideTimer = null;

  function showHover() {
    clearTimeout(hideTimer);
    if (hovercard && window.innerWidth > 768) hovercard.style.display = 'block';
  }

  function hideHover() {
    hideTimer = setTimeout(() => {
      if (hovercard) hovercard.style.display = 'none';
    }, 150);
  }

  hoverTrig?.addEventListener('mouseenter', showHover);
  hoverTrig?.addEventListener('mouseleave', hideHover);
  hovercard?.addEventListener('mouseenter', showHover);
  hovercard?.addEventListener('mouseleave', hideHover);

  // Lightbox logic
  function openLightbox() {
    lightbox.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    if (pdfUrl) initPdf();
  }

  function closeLightbox() {
    lightbox.style.display = 'none';
    document.body.style.overflow = '';
  }

  trigger?.addEventListener('click', openLightbox);
  lightbox?.addEventListener('click', closeLightbox);
  closeBtn?.addEventListener('click', (e) => { e.stopPropagation(); closeLightbox(); });

  document.addEventListener('keydown', (e) => {
    if (lightbox?.style.display === 'flex') {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight' && pdfUrl) nextPage();
      if (e.key === 'ArrowLeft' && pdfUrl) prevPage();
    }
  });

  let pdfDoc = null;
  let currentPage = 1;
  let rendering = false;
  let pdfInitialized = false;

  async function initPdf() {
    if (pdfInitialized) return;
    pdfInitialized = true;
    await new Promise((resolve) => {
      if (window.pdfjsLib) { resolve(); return; }
      const script = document.createElement('script');
      script.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
      script.onload = () => resolve();
      document.head.appendChild(script);
    });
    const pdfjsLib = window.pdfjsLib;
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    pdfDoc = await pdfjsLib.getDocument(pdfUrl).promise;
    updatePageInfo();
    renderPage(1);
  }

  function updatePageInfo() {
    const info = document.getElementById('page-info-' + cardId);
    if (info && pdfDoc) info.textContent = currentPage + ' / ' + pdfDoc.numPages;
  }

  async function renderPage(num) {
    if (!pdfDoc || rendering) return;
    rendering = true;
    const page = await pdfDoc.getPage(num);
    const canvas = document.getElementById('pdf-canvas-' + cardId);
    const container = canvas.parentElement;
    const scale = Math.min(
      (container.clientWidth - 32) / page.getViewport({ scale: 1 }).width,
      (container.clientHeight - 32) / page.getViewport({ scale: 1 }).height
    );
    const viewport = page.getViewport({ scale });
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
    rendering = false;
    updatePageInfo();
  }

  function nextPage() {
    if (pdfDoc && currentPage < pdfDoc.numPages) { currentPage++; renderPage(currentPage); }
  }

  function prevPage() {
    if (pdfDoc && currentPage > 1) { currentPage--; renderPage(currentPage); }
  }

  document.getElementById('next-' + cardId)?.addEventListener('click', (e) => { e.stopPropagation(); nextPage(); });
  document.getElementById('prev-' + cardId)?.addEventListener('click', (e) => { e.stopPropagation(); prevPage(); });
</script>
